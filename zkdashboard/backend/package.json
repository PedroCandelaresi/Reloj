{
  "name": "backend",
  "version": "1.0.0",
  "scripts": {
    "build": "nest build",
    "start": "node dist/main.js",
    "start:prod": "node dist/main.js",
    "start:dev": "nest start --watch",
    "seed": "node -r ts-node/register -r tsconfig-paths/register src/seed.ts",
    "typeorm": "node -r ts-node/register -r tsconfig-paths/register ./node_modules/typeorm/cli.js -d src/database/data-source.ts",
    "typeorm:prod": "node ./node_modules/typeorm/cli.js -d dist/database/data-source.js",
    "migration:create": "sh -c 'test -n \"$npm_config_name\" || { echo \"Uso: npm run migration:create --name=NombreMigracion\" >&2; exit 1; }; npm run typeorm -- migration:create src/database/migrations/$npm_config_name'",
    "migration:generate": "sh -c 'test -n \"$npm_config_name\" || { echo \"Uso: npm run migration:generate --name=NombreMigracion\" >&2; exit 1; }; npm run typeorm -- migration:generate src/database/migrations/$npm_config_name'",
    "migration:run": "npm run typeorm -- migration:run",
    "migration:revert": "npm run typeorm -- migration:revert",
    "migration:show": "npm run typeorm -- migration:show",
    "migration:run:prod": "npm run typeorm:prod -- migration:run",
    "migration:revert:prod": "npm run typeorm:prod -- migration:revert"
  },
  "dependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^3.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/jwt": "^10.0.0",
    "@nestjs/passport": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/typeorm": "^10.0.0",
    "bcrypt": "^5.1.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "exceljs": "^4.4.0",
    "helmet": "^7.1.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pdfkit": "^0.15.0",
    "pg": "^8.11.3",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.17"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^4.17.17",
    "@types/node": "^20.3.1",
    "@types/passport-jwt": "^4.0.0",
    "@types/pdfkit": "^0.13.4",
    "dotenv": "^16.4.5",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.1.3"
  }
}
