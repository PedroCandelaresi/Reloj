# Copiar a .env y ajustar valores sensibles antes de levantar.
# cp .env.example .env

# ── Postgres ──────────────────────────────────────────────────────────────────
DB_USERNAME=zkuser
DB_PASSWORD=zkpassword
DB_NAME=zkdashboard
DB_PORT=5432

# ── Backend ───────────────────────────────────────────────────────────────────
BACKEND_PORT=4201
JWT_SECRET=cambia-esto-por-un-secreto-seguro
JWT_EXPIRES_IN=7d

# URL pública con la que el frontend (navegador) llega al backend.
# Se usa para CORS. En prod reemplazar por el dominio real.
FRONTEND_URL=http://localhost:4200

# Usuario admin inicial (solo se crea si no existe ninguno)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# ── Frontend ──────────────────────────────────────────────────────────────────
FRONTEND_PORT=4200

# URL interna con la que el frontend (server-side) llega al backend dentro de
# la red de Docker. Usar el nombre del servicio (backend), no localhost.
INTERNAL_API_URL=http://backend:4201
